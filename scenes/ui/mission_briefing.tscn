[ext_resource type="FontFile" path="res://assets/fonts/noto_sans_kr_ui_subset.ttf" id="3_ko_font"]

[sub_resource type="StyleBoxFlat" id="Style_card"]
bg_color = Color(0.018, 0.045, 0.078, 0.98)
border_width_left = 2
border_width_top = 2
border_width_right = 2
border_width_bottom = 2
